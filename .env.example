# Configuração de Timezone
# Define o timezone padrão para o sistema de horário comercial
# Se não definido ou inválido, será usado America/Sao_Paulo como padrão
#TIMEZONE=America/Sao_Paulo

# Exemplos de outros timezones válidos:
# TIMEZONE=America/New_York
# TIMEZONE=America/New_York
# TIMEZONE=Europe/Lisbon

